{
  "manifest_version": 3,
  "name": "REIT Fair Value",
  "description": "Compara el precio de REIT en IEB Mas, Balanz, IOL y PPI con el fair value oficial de reit.com.ar",
  "version": "1.4.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://reit.com.ar/*",
    "https://hb.iebmas.com.ar/*",
    "https://clientes.balanz.com/*",
    "https://iol.invertironline.com/*",
    "https://trading.portfoliopersonal.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hb.iebmas.com.ar/instrumento/REIT*",
        "https://clientes.balanz.com/app/detalleinstrumento*",
        "https://iol.invertironline.com/titulo/cotizacion/BCBA/REIT*",
        "https://trading.portfoliopersonal.com/Cotizaciones/Item/925077*"
      ],
      "js": ["src/brokers.js", "src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
